<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Agape Property Management</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root { --cream:#f0ede6; --ink:#1a1714; --ink3:#7a7268; --gold:#4CAF50; --border:rgba(26,23,20,0.12); }
* { box-sizing:border-box; margin:0; padding:0; }
body { background:var(--cream); color:var(--ink); font-family:'Jost',sans-serif; font-weight:300; min-height:100vh; }

.hero { background:var(--ink); padding:60px 32px 56px; text-align:center; }
.logo { height:56px; filter:invert(1) brightness(0.88); margin-bottom:28px; }
.hero-tag { font-size:9px; letter-spacing:0.28em; text-transform:uppercase; color:var(--gold); margin-bottom:12px; }
.hero-title { font-family:'Cormorant Garamond',serif; font-size:44px; color:rgba(240,237,230,0.95); line-height:1.1; margin-bottom:12px; }
.hero-sub { font-size:13px; color:rgba(240,237,230,0.4); max-width:420px; margin:0 auto; line-height:1.8; }

.section { max-width:720px; margin:0 auto; padding:48px 24px; }
.section-label { font-size:9px; letter-spacing:0.22em; text-transform:uppercase; color:var(--ink3); margin-bottom:20px; padding-bottom:10px; border-bottom:1px solid var(--border); }

.card-grid { display:grid; grid-template-columns:1fr 1fr; gap:2px; margin-bottom:40px; }
@media(max-width:520px){ .card-grid{grid-template-columns:1fr;} }

.card { background:white; border:1px solid var(--border); padding:24px 22px; text-decoration:none; color:var(--ink); display:block; transition:all 0.18s; }
.card:hover { background:var(--ink); }
.card:hover .card-title { color:rgba(240,237,230,0.95); }
.card:hover .card-sub { color:rgba(240,237,230,0.4); }
.card:hover .card-icon { color:var(--gold); }
.card-icon { font-size:22px; margin-bottom:10px; display:block; color:var(--ink3); transition:color 0.18s; }
.card-title { font-family:'Cormorant Garamond',serif; font-size:20px; margin-bottom:4px; transition:color 0.18s; }
.card-sub { font-size:12px; color:var(--ink3); line-height:1.5; transition:color 0.18s; }
.card-tag { display:inline-block; font-size:9px; letter-spacing:0.1em; text-transform:uppercase; padding:3px 8px; margin-top:8px; }
.tag-host { background:#d4edda; color:#2d6a4f; }
.tag-worker { background:#E8F5E9; color:#388E3C; }
.tag-admin { background:#1a1714; color:rgba(240,237,230,0.7); }

.footer { background:var(--ink); padding:28px 32px; text-align:center; }
.footer-text { font-size:11px; color:rgba(240,237,230,0.25); letter-spacing:0.06em; }
</style>
</head>
<body>

<div class="hero">
  <img class="logo" src="agape-logo.png" alt="Agape Property Management">
  <div class="hero-tag">Premium property services</div>
  <div class="hero-title">Welcome to Agape.</div>
  <div class="hero-sub">Premium property management for Airbnb hosts and long-term rental owners in Dallas, TX.</div>
</div>

<div class="section">

  <div class="section-label">For property owners</div>
  <div class="card-grid">
    <a class="card" href="host/">
      <span class="card-icon">🏠</span>
      <div class="card-title">List your property</div>
      <div class="card-sub">New host? Set up your property and get instant portal access in 3 minutes.</div>
      <span class="card-tag tag-host">New host signup</span>
    </a>
    <a class="card" href="portal/">
      <span class="card-icon">⊞</span>
      <div class="card-title">Host portal</div>
      <div class="card-sub">View reports, track jobs, approve payments, and manage your properties.</div>
      <span class="card-tag tag-host">Existing hosts</span>
    </a>
  </div>

  <div class="section-label">For service providers</div>
  <div class="card-grid">
    <a class="card" href="join/">
      <span class="card-icon">✦</span>
      <div class="card-title">Join the network</div>
      <div class="card-sub">Apply to become an Agape service provider. Cleaners, plumbers, HVAC, lawn, and more.</div>
      <span class="card-tag tag-worker">Apply now</span>
    </a>
    <a class="card" href="worker/">
      <span class="card-icon">📋</span>
      <div class="card-title">Job checklist</div>
      <div class="card-sub">Active workers — open your job checklist, check in, and submit your report here.</div>
      <span class="card-tag tag-worker">Workers only</span>
    </a>
  </div>

  <div class="section-label">Platform tools</div>
  <div class="card-grid">
    <a class="card" href="services/">
      <span class="card-icon">🛍</span>
      <div class="card-title">All service checklists</div>
      <div class="card-sub">Cleaning, plumbing, HVAC, lawn, laundry, moving, errands & staging.</div>
      <span class="card-tag tag-admin">7 services</span>
    </a>
    <a class="card" href="pay/">
      <span class="card-icon">💳</span>
      <div class="card-title">Payment approval</div>
      <div class="card-sub">Review a completed job report and release payment to your service provider.</div>
      <span class="card-tag tag-host">Hosts</span>
    </a>
    <a class="card" href="report/">
      <span class="card-icon">📄</span>
      <div class="card-title">Cleaner report</div>
      <div class="card-sub">Standard cleaning inspection report with photos and inventory checklist.</div>
      <span class="card-tag tag-worker">Workers</span>
    </a>
    <a class="card" href="dispatch/">
      <span class="card-icon">⚙</span>
      <div class="card-title">Auto-dispatch setup</div>
      <div class="card-sub">Connect your Airbnb calendar and automate job dispatch to your cleaners.</div>
      <span class="card-tag tag-admin">Admin</span>
    </a>
  </div>

</div>

<div class="footer">
  <div class="footer-text">Agape Property Management · Dallas, TX · agapepm.netlify.app</div>
</div>

</body>
</html>
